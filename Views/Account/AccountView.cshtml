@model BankingManegmentSystem.Models.Account

@{
    ViewData["Title"] = "Account View";
}

<div class="container mt-4">

    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-primary text-white rounded-top-4">
            <h4 class="mb-0">Account Details</h4>
        </div>

        <div class="card-body">

            <div class="row mb-3">
                <div class="col-md-6">
                    <strong class="fs-5">Account Name:</strong>
                    <p class="text-black">@Model.AccountName</p>
                </div>

                <div class="col-md-6">
                    <strong class="fs-5">Account Number:</strong>
                    <p class="text-black">@Model.AccountNumber</p>
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <strong class="fs-5">Balance:</strong>
                    <p class="text-success fw-bold">@Model.Balance ৳</p>
                </div>

                <div class="col-md-6">
                    <strong class="fs-5">User Id:</strong>
                    <p class="text-black">@Model.UserId</p>
                </div>
            </div>

            <div class="mt-3">
                <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">
                    Back
                </a>
            </div>

        </div>
    </div>

    <div class="card shadow-lg mt-4 border-0 rounded-4">
        <div class="card-header bg-secondary text-white rounded-top-4">
            <h5 class="mb-0">Transaction History</h5>
        </div>

        <div class="card-body">

            @if (Model.Transaction != null && Model.Transaction.Any())
            {
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>No.</th>
                            <th>Amount</th>
                            <th>Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int count = 1;
                        }
                        @foreach (var transaction in Model.Transaction.OrderByDescending(t => t.TransctionDateTime))
                        {
                            <tr>
                                <td>@count</td>
                                <td class="fw-semibold">@transaction.Amount ৳</td>
                                <td>@transaction.TransctionDateTime.ToString("dd MMM yyyy hh:mm tt")</td>
                                <td>
                                    @await Html.PartialAsync("_TransactionType", transaction.TransactionType)
                                </td>
                            </tr>
                            count++;
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-info text-center">
                    No transactions found.
                </div>
            }

        </div>
    </div>

</div>