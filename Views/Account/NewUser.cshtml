@{
    ViewData["Title"] = "Welcome to Banking System";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-light text-center">
                    <h3 class="fw-semibold text-primary">Welcome to Our Banking System</h3>
                </div>
                <div class="card-body p-4 text-center">
                    <h5 class="fw-medium mb-3">Your financial journey starts here!</h5>
                    <p class="text-muted fs-5">
                        Banking is not just about money, it’s about building trust, security, and a brighter future.
                        Every great journey begins with a single step — and with us, that step is safe and strong.
                        We believe in empowering you to achieve your dreams through smart and secure financial solutions.
                    </p>

                    <hr class="my-4" />

                    <p class="fst-italic text-secondary">
                        "A bank is more than a vault of numbers — it is a partner in your growth."
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>