@model BankingManegmentSystem.Models.Account

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div class="card mb-4">
    <div class="card-header">
        <h4>Account Information</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.AccountName)</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.AccountName)</dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.AccountNumber)</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.AccountNumber)</dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Balance)</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.Balance)</dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.UserId)</dt>
            <dd class="col-sm-10">@Html.DisplayFor(model => model.UserId)</dd>
        </dl>
    </div>
</div>

<div class="mb-3">
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

<h2>All Transactions</h2>

@if (Model.Transaction != null && Model.Transaction.Any())
{
    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Amount</th>
                <th>Date Time</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @{
                int count = 1;
            }
            @foreach (var transaction in Model.Transaction)
            {
                <tr>
                    <td>@count</td>
                    <td>@transaction.Amount</td>
                    <td>@transaction.TransctionDateTime.ToString("dd-MMM-yyyy HH:mm")</td>
                    <td>
                        @await Html.PartialAsync("~/Views/Shared/_TransactionType.cshtml", transaction.TransactionType)
                    </td>
                </tr>
                count++;
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        No transactions found for this account.
    </div>
}