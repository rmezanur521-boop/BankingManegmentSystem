@model IEnumerable<BankingManegmentSystem.Models.Transaction>

@{
    ViewData["Title"] = "Index";
}

<div class="page-wrapper" style="min-height:100vh; background-color:#f8f9fa;">

    <div class="container py-5">
        <h1 class="text-center mb-4 fw-semibold">All Transactions</h1>

        <table class="table table-striped table-hover shadow-sm rounded">
            <thead class="table-light">

                <tr>
                    <th>
                        @Html.DisplayNameFor(model => model.Account.AccountName)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Amount)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.TransctionDateTime)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.TransactionType)
                    </th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @item.Account.AccountName
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Amount)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.TransctionDateTime)
                        </td>
                        <td>
                            @await Html.PartialAsync("~/Views/Shared/_TransactionType.cshtml", item.TransactionType)
                        </td>
                        <td>

                            <a asp-action="Details" asp-route-id="@item.Id">Details</a>

                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>